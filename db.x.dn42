$TTL 300
@           IN  SOA  anycast.baka.dn42. xiexilin.com. (
                     2026031801 ; Serial
                     4H         ; Refresh
                     1H         ; Retry
                     7D         ; Expire
                     4H )       ; Negative Cache TTL


@              IN  NS   anycast.baka.dn42.
dns-test       IN  A    172.20.154.244


@               IN  A    172.20.154.230
@               IN  AAAA fddf:3681:e80:230::1
mail           IN  A    172.20.154.230
mail           IN  AAAA fddf:3681:e80:230::1
@               IN  MX     mail.x.dn42
mail           IN  TXT    v=spf1 mx ~all
@               IN  TXT    v=spf1 mx ~all
default._domainkey.x.dn42    IN  TXT    v=DKIM1; k=rsa; 
_dmarc      IN  TXT    v=DMARC1; p=quarantine; ruf=mailto:bingxin@x.dn42
_mta-sts    IN  TXT    v=STSv1; id=1
_smtp._tls  IN  TXT    v=TLSRPTv1;rua=mailto:binxgin@x.dn42
